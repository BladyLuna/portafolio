#!/usr/bin/env bash
# Simple pre-push hook to run secret scan and show staged files
echo "Running pre-push checks..."
echo "Staged files:"
git diff --name-only --staged || true
node ./scripts/check_secrets.js
rc=$?
if [ $rc -ne 0 ]; then
  echo "Potential secrets detected. Push aborted. Review staged files and remove secrets."
  exit 1
fi
echo "Pre-push checks passed."
exit 0
