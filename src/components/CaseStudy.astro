---
import Badge from "./ui/Badge.astro";
import SectionTitle from "./ui/SectionTitle.astro";
---

<section class="px-6 md:px-12 max-w-4xl mx-auto py-24">
  <SectionTitle title="Proyecto Destacado" subtitle="Sistema Hospitalario de Gestión de Turnos" />

  <div class="relative group">
    <div class="absolute -inset-px bg-gradient-to-b from-blue-500/10 via-transparent to-transparent rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" />
    <div class="relative bg-white/[0.03] border border-white/[0.06] rounded-xl p-6 md:p-8 backdrop-blur-sm">
      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white/[0.03] border border-white/[0.06] rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-blue-400 font-mono">8</p>
          <p class="text-xs text-[#909090] mt-1">Módulos</p>
        </div>
        <div class="bg-white/[0.03] border border-white/[0.06] rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-blue-400 font-mono">3+</p>
          <p class="text-xs text-[#909090] mt-1">Roles</p>
        </div>
        <div class="bg-white/[0.03] border border-white/[0.06] rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-blue-400 font-mono">4</p>
          <p class="text-xs text-[#909090] mt-1">Contenedores</p>
        </div>
      </div>
      <div class="space-y-6">
        <div class="flex items-start gap-4">
          <div class="w-8 h-8 rounded-lg bg-blue-500/10 border border-blue-500/20 flex items-center justify-center shrink-0 mt-0.5">
            <span class="text-xs font-bold text-blue-400">P</span>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-[#e0e0e0] mb-1">Problema</h3>
            <p class="text-[#909090] text-sm leading-relaxed">
              Procesos manuales de asignación de turnos generan errores, demoras y falta de visibilidad sobre la disponibilidad del personal médico.
            </p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-8 h-8 rounded-lg bg-green-500/10 border border-green-500/20 flex items-center justify-center shrink-0 mt-0.5">
            <span class="text-xs font-bold text-green-400">S</span>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-[#e0e0e0] mb-1">Solución</h3>
            <p class="text-[#909090] text-sm leading-relaxed">
              Sistema web modular con autenticación, roles y permisos (RBAC), dashboard administrativo y control de turnos en tiempo real.
            </p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-8 h-8 rounded-lg bg-purple-500/10 border border-purple-500/20 flex items-center justify-center shrink-0 mt-0.5">
            <span class="text-xs font-bold text-purple-400">A</span>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-[#e0e0e0] mb-1">Arquitectura</h3>
            <div class="bg-dark-900 border border-white/[0.06] rounded-lg p-3 mt-2 overflow-x-auto">
              <pre class="text-xs text-[#b0b0b0] font-mono leading-relaxed">
┌──────────────┐    ┌──────────────┐    ┌──────────────┐
│   Cliente    │───>│   Laravel    │───>│   MySQL      │
│  (Browser)   │    │   Backend    │    │   Database   │
└──────────────┘    └──────────────┘    └──────────────┘
                           │
                    ┌──────┴──────┐
                    │   Docker    │
                    │ Containers  │
                    └─────────────┘
              </pre>
            </div>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-8 h-8 rounded-lg bg-yellow-500/10 border border-yellow-500/20 flex items-center justify-center shrink-0 mt-0.5">
            <span class="text-xs font-bold text-yellow-400">T</span>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-[#e0e0e0] mb-1">Stack</h3>
            <div class="flex flex-wrap gap-2 mt-2">
              {["Laravel", "PHP", "MySQL", "Docker", "HTML/CSS", "JavaScript", "Git"].map((t) => (
                <span class="px-2.5 py-1 bg-white/[0.04] border border-white/[0.06] rounded-md text-xs text-[#b0b0b0] font-mono">
                  {t}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
      <div class="mt-8 pt-6 border-t border-white/[0.06] text-center">
        <a
          href="/projects/hospital-system/"
          class="group inline-flex items-center gap-2 text-sm text-blue-400 hover:text-blue-300 font-medium transition-colors"
        >
          Ver caso de estudio completo
          <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
