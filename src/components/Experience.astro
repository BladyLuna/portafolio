---
import { profile } from "../data/profile";
import SectionTitle from "./ui/SectionTitle.astro";
import Badge from "./ui/Badge.astro";
---

<section id="experience" class="px-6 md:px-12 max-w-4xl mx-auto py-24">
  <SectionTitle title="Experiencia" subtitle="Proyectos que he construido" />
  <div class="space-y-6">
    {profile.experience.map((exp) => (
      <div class="relative group">
        <div class="absolute -inset-px bg-gradient-to-b from-white/[0.04] to-transparent rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" />
        <div class="relative bg-white/[0.03] border border-white/[0.06] rounded-xl p-6 backdrop-blur-sm transition-all duration-200 group-hover:border-white/[0.12]">
          <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
            <div>
              <h3 class="text-lg font-semibold text-[#fafafa]">{exp.title}</h3>
              <p class="text-sm text-[#a0a0a0] mt-0.5">{exp.role}</p>
            </div>
            <Badge>{exp.period}</Badge>
          </div>
          <p class="text-sm text-[#b0b0b0] leading-relaxed mb-4">{exp.description}</p>
          <ul class="space-y-2">
            {exp.highlights.map((h) => (
              <li class="flex items-start gap-2 text-sm text-[#909090]">
                <span class="w-1.5 h-1.5 rounded-full bg-blue-400/60 mt-1.5 shrink-0" />
                {h}
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </div>
</section>
