---
import { profile } from "../data/profile";
---

<section class="relative min-h-screen flex flex-col justify-center px-6 md:px-12 max-w-4xl mx-auto overflow-hidden">
  <div class="absolute -top-40 -right-40 w-80 h-80 bg-blue-500/10 rounded-full blur-[120px] animate-glow-pulse pointer-events-none" />
  <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-blue-500/5 rounded-full blur-[120px] animate-glow-pulse pointer-events-none" style="animation-delay: 1.5s" />
  <div class="relative animate-fade-in-up">
    <div class="flex items-center gap-2 text-blue-400/80 font-mono text-xs mb-6">
      <span class="w-2 h-2 rounded-full bg-green-400" />
      <span>Disponible para oportunidades</span>
    </div>
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight text-[#fafafa] leading-[1.05]">
      {profile.name}
    </h1>
    <p class="text-xl md:text-2xl text-[#a0a0a0] mt-4 max-w-2xl font-medium">
      {profile.title}
    </p>
    <p class="text-base md:text-lg text-[#707070] mt-3 max-w-xl leading-relaxed">
      {profile.subtitle}
    </p>
    <div class="flex flex-wrap gap-2 mt-6">
      {["Laravel", "PHP", "MySQL", "Docker", "Linux", "Git"].map((t) => (
        <span class="px-3 py-1 text-xs font-mono text-[#909090] bg-white/[0.04] border border-white/[0.06] rounded-full">
          {t}
        </span>
      ))}
    </div>
    <div class="flex flex-wrap gap-4 mt-8">
      <a
        href="/projects/hospital-system/"
        class="group inline-flex items-center px-5 py-2.5 bg-blue-500 hover:bg-blue-400 text-white text-sm font-medium rounded-lg transition-all duration-200 shadow-lg shadow-blue-500/20 hover:shadow-blue-400/30"
      >
        Ver proyectos
        <svg class="ml-2 w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
      <a
        href="#contact"
        class="inline-flex items-center px-5 py-2.5 bg-white/[0.04] border border-white/[0.1] hover:bg-white/[0.08] hover:border-white/[0.18] text-[#e0e0e0] text-sm font-medium rounded-lg transition-all duration-200"
      >
        Contacto
      </a>
    </div>
  </div>
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-fade-in">
    <div class="flex flex-col items-center gap-2">
      <span class="text-[10px] font-mono text-[#505050] tracking-widest uppercase">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-[#505050] to-transparent" />
    </div>
  </div>
</section>
