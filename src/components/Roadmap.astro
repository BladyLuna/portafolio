---
import { profile } from "../data/profile";
import SectionTitle from "./ui/SectionTitle.astro";
---

<section id="roadmap" class="px-6 md:px-12 max-w-4xl mx-auto py-24">
  <SectionTitle title="Roadmap" subtitle="Mi trayectoria de aprendizaje y hacia dónde voy" />
  <div class="relative">
    <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-blue-500/30 via-white/[0.08] to-transparent md:-translate-x-px" />
    <div class="space-y-8">
      {profile.roadmap.map((item, i) => (
        <div class={`relative flex flex-col md:flex-row gap-4 md:gap-8 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
          <div class="hidden md:block flex-1" />
          <div class="absolute left-2.5 md:left-1/2 top-1 w-4 h-4 rounded-full bg-blue-500 border-[3px] border-dark-950 md:-translate-x-2 z-10 shadow-lg shadow-blue-500/20" />
          <div class="flex-1 pl-10 md:pl-0">
            <div class="relative group">
              <div class="absolute -inset-px bg-gradient-to-b from-white/[0.04] to-transparent rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" />
              <div class="relative bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 backdrop-blur-sm transition-all duration-200 group-hover:border-white/[0.12]">
                <div class="flex items-center gap-3 mb-1">
                  <span class="text-xs font-mono text-blue-400 font-semibold">{item.year}</span>
                  <span class="text-sm font-semibold text-[#e0e0e0]">{item.label}</span>
                </div>
                <p class="text-sm text-[#909090]">{item.description}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
