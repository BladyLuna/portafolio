---
export interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<div class="mb-12">
  <div class="flex items-center gap-3 mb-2">
    <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/[0.06] to-transparent max-w-[60px]" />
    <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold tracking-tight text-[#fafafa]">
      {title}
    </h2>
  </div>
  {subtitle && (
    <p class="mt-2 text-[#a0a0a0] text-base max-w-xl ml-[76px]">{subtitle}</p>
  )}
</div>
